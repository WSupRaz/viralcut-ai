# Copy to .env and fill in. Never commit the real .env.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://viralcut:viralcut_dev@postgres:5432/viralcut

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Cloudflare R2 (S3-compatible) ---
# Local dev defaults below point at the bundled MinIO service (infra/docker-compose.dev.yml)
# so nobody needs real R2 credentials to run the stack. For staging/prod: clear
# R2_ENDPOINT_URL, set R2_ACCOUNT_ID, and use real R2 access keys.
R2_ENDPOINT_URL=http://minio:9000
# The API only uses this to sign presigned URLs, never to move bytes itself --
# it must be a host the *browser* can reach, unlike R2_ENDPOINT_URL above
# (Docker-internal, used for real server-to-server transfers). Not needed
# outside local dev: real R2 has one public endpoint for everyone.
R2_PUBLIC_ENDPOINT_URL=http://localhost:9000
R2_ACCOUNT_ID=dev
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=viralcut-assets
R2_PUBLIC_BASE_URL=

# --- Render worker (Node/Remotion HTTP service) ---
RENDER_WORKER_URL=http://render-worker:3001

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_MINUTES=10080

# --- AI providers ---
# Primary edit-plan provider (ADR-0005/0006). OPENROUTER_API_KEY is an
# optional fallback used only if the Claude call fails -- also covers the
# original "Gemini fallback" need, since OpenRouter can route to Gemini
# models through the same key. Leave blank if you don't have one, the
# edit-plan worker just skips the fallback and raises the original error.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
# Primary ASR provider (ADR-0001). GROQ_API_KEY is an optional fallback --
# leave blank if you don't have one, the metadata worker just skips it.
OPENAI_API_KEY=
GROQ_API_KEY=

# --- B-roll providers (Phase 2) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Billing (Phase 2) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
