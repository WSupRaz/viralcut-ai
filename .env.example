# Copy to .env and fill in. Never commit the real .env.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://viralcut:viralcut_dev@postgres:5432/viralcut

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=viralcut-assets
R2_PUBLIC_BASE_URL=

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN_MINUTES=10080

# --- AI providers ---
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPGRAM_API_KEY=
GROQ_API_KEY=

# --- B-roll providers (Phase 2) ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Billing (Phase 2) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
